    {
      "title": "Framework boundary",
      "detail": "This repo owns the reusable red-team runner, manifest schema, corpus, scoring, storage, and release workflow."
    },
    {
      "title": "SOO boundary",
      "detail": "student-onboarding-orchestration consumes the framework for the three LiveKit agents selected for v0."
    },
    {
      "title": "Production moderation",
      "detail": "Existing app-level input moderation is not replaced; the MVP validates agent output behavior and deploy safety."
    },
    {
      "title": "Decision posture",
      "detail": "Hard constraints, ADRs, Ask First rules, and bilingual-doc conventions remain binding for every new step."
    }
  ],
  "risks": [
    {
