# Local environment for running the livekit-agents worker against the
# LiveKit Server brought up by docker-compose.yml.
#
# Copy to `.env.local` and fill in the OpenAI key. The .env.local file is
# .gitignored.

# --- LiveKit (matches docker-compose.yml defaults) ---
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret

# --- OpenAI (required by the Mouth / Realtime API) ---
OPENAI_API_KEY=sk-replace-me

# --- Supabase (optional in local mode; the agent's egress writes recordings
#     to Supabase Storage. For red-team runs we typically skip recording.) ---
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_ANON_KEY=placeholder
SUPABASE_S3_ENDPOINT=
SUPABASE_S3_ACCESS_KEY=
SUPABASE_S3_SECRET_KEY=
SUPABASE_S3_BUCKET=
SUPABASE_S3_REGION=us-east-1

# --- Webhook (local development override) ---
# If set, the agent POSTs interview results here when a candidate disconnects.
# Useful for verifying the finalization payload without running the Go tutors-service.
WEBHOOK_LOCAL_URL=http://localhost:9999/redteam/webhook

# --- Logging ---
LOG_LEVEL=info
NODE_ENV=development
